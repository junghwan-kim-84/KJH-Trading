// © Zeiierman
//@version=6
indicator('Trend-Tracker', overlay = true, max_bars_back = 5000, max_labels_count = 500, max_polylines_count = 100)

// ~~ Tooltips {
var string t1 = "Number of bars used to detect swing highs and lows. Larger values identify bigger, more significant swings but react slower. Smaller values detect more frequent swings but may produce more noise."
var string t2 = "Controls how quickly the VWAP adjusts to new price action. Lower values make the VWAP react faster (tighter to price), higher values make it smoother and slower to change."
var string t3 = "When enabled, the VWAP reaction speed changes automatically based on market volatility. High volatility shortens the tracking period (more responsive), low volatility lengthens it (smoother)."
var string t4 = "Controls how strongly volatility influences the VWAP reaction speed. Values above 1 increase the effect of volatility changes; values below 1 make it less sensitive to volatility."
var string t5 = "Color used for positive swing labels such as HH and HL."
var string t6 = "Color used for negative swing labels such as LL and LH."
var string t7 = "Color used for VWAP lines when in an uptrend."
var string t8 = "Color used for VWAP lines when in a downtrend."
var string t9 = "Width of the VWAP lines drawn on the chart. Larger values make the lines thicker and more visible."
var string t10 = "Show or hide the anchored VWAP lines on the chart. The VWAP value still remains available for internal calculations even when hidden."
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ Inputs {
prd      = input.int(14, title='Swing Period', minval=2, group='Swing Points', tooltip=t1)
baseAPT  = input.float(28, 'Adaptive Price Tracking', minval=1, step=1, group='Swing Points', tooltip=t2)
useAdapt = input.bool(true, 'Adapt APT by ATR ratio', group='Swing Points', tooltip=t3)
volBias  = input.float(1.4, 'Volatility Bias', minval=0.1, step=0.1, group='Swing Points', tooltip=t4)

highS = input.color(color.rgb(0, 107, 116), title="Swing Labels", group="Style", inline="Swing", tooltip=t5)
lowS  = input.color(color.rgb(145, 22, 31), title="", group="Style", inline="Swing", tooltip=t6)
showAnchoredVWAP = input.bool(false, title="Show Anchored VWAP", group="Style", tooltip=t10)
S     = input.color(color.rgb(233, 92, 146), title="VWAP Lines", group="Style", inline="VWAP", tooltip=t7)
R     = input.color(color.rgb(83, 198, 220), title="", group="Style", inline="VWAP", tooltip=t8)
xx    = input.int(2, minval=1, title="", group="Style", inline="VWAP", tooltip=t9)

// Ribbon
ribbonGroup       = "Ribbon"
showRibbon        = input.bool(true, "Show Ribbon", group=ribbonGroup)
ribbonSource      = input.source(close, "Source", group=ribbonGroup)
ribbonExponential = input.bool(true, "Exponential", group=ribbonGroup)
showRibbon100     = input.bool(true, "MA 100", group=ribbonGroup)
showRibbon200     = input.bool(true, "MA 200", group=ribbonGroup)

// Signal MA (calculation only)
maGroup  = "Signal Moving Average"
maLength = input.int(9, "MA Length", minval=1, group=maGroup)
maSource = input.source(close, "MA Source", group=maGroup)

// Alignment
alignGroup      = "Alignment"
showAlignmentBg = input.bool(false, "Show Alignment Background", group=alignGroup)

bullAlignColor  = input.color(color.new(color.green, 90), "Bull Alignment", group=alignGroup, inline="al1")
bearAlignColor  = input.color(color.new(color.purple, 90), "BEAR Alignment", group=alignGroup, inline="al1")
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ Global Variable {
b = bar_index
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ PIVOTS Variables {
var ph   = float(na)
var pl   = float(na)
var phL  = b
var plL  = b
var prev = float(na)

ph  := ta.highestbars(high, prd) == 0 ? high : ph
pl  := ta.lowestbars(low,  prd) == 0 ? low  : pl
phL := ta.highestbars(high, prd) == 0 ? b   : phL
plL := ta.lowestbars(low,  prd) == 0 ? b    : plL
dir = phL > plL ? 1 : -1
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ Adaptation {
atrLen = 50
atr    = ta.atr(atrLen)
atrAvg = ta.rma(atr, atrLen)
ratio  = atrAvg > 0 ? atr / atrAvg : 1.0

aptRaw     = useAdapt ? baseAPT / math.pow(ratio, volBias) : baseAPT
aptClamped = math.max(5.0, math.min(300.0, aptRaw))
aptSeries  = math.round(aptClamped)

alphaFromAPT(apt) =>
    decay = math.exp(-math.log(2.0) / math.max(1.0, apt))
    1.0 - decay
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ VWAP Variables {
var p   = hlc3 * volume
var vol = volume
var float vap = na

type dataPoints
    array<chart.point> points
    polyline poly = na

var vwap = dataPoints.new(array.new<chart.point>())
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ Ribbon {
ribbonMa(length) =>
    ribbonExponential ? ta.ema(ribbonSource, length) : ta.sma(ribbonSource, length)

ribbon20  = ribbonMa(20)
ribbon25  = ribbonMa(25)
ribbon30  = ribbonMa(30)
ribbon35  = ribbonMa(35)
ribbon40  = ribbonMa(40)
ribbon45  = ribbonMa(45)
ribbon50  = ribbonMa(50)
ribbon100 = showRibbon and showRibbon100 ? ribbonMa(100) : na
ribbon200 = showRibbon and showRibbon200 ? ribbonMa(200) : na

plot(showRibbon ? ribbon20 : na, title='MA 20', color=#FFFF0080)
plot(showRibbon ? ribbon25 : na, title='MA 25', color=#FFDF0080)
plot(showRibbon ? ribbon30 : na, title='MA 30', color=#FFBF0080)
plot(showRibbon ? ribbon35 : na, title='MA 35', color=#FF9F0080)
plot(showRibbon ? ribbon40 : na, title='MA 40', color=#FF7F0080)
plot(showRibbon ? ribbon45 : na, title='MA 45', color=#FF5F0080)
plot(showRibbon ? ribbon50 : na, title='MA 50', color=#FF3F0080)

p100 = plot(ribbon100, title='MA 100', color=#FF0000FF)
p200 = plot(ribbon200, title='MA 200', color=#800000FF)
fill(p100, p200, color=ribbon100 > ribbon200 ? #4CAF5033 : #FF525233, title='MA Fill')
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ MA (calculation only) {
maValue = ta.sma(maSource, maLength)
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}

// ~~ Main {
if dir != dir[1]
    x   = dir > 0 ? plL : phL
    y   = dir > 0 ? pl  : ph
    loc = dir > 0 ? label.style_label_up : label.style_label_down
    txt = dir > 0 and pl < prev ? 'LL' : dir > 0 and pl > prev ? 'HL' : dir < 0 and ph < prev ? 'LH' : dir < 0 and ph > prev ? 'HH' : ''
    col = txt == 'HH' or txt == 'HL' ? highS : txt == 'LL' or txt == 'LH' ? lowS : color.gray
    label.new(x, y, text=txt, style=loc, color=color.new(col, 20), textcolor=color.white)
    prev := dir > 0 ? ph[1] : pl[1]

    barsback = b - x
    p   := y * volume[barsback]
    vol := volume[barsback]
    vap := p / vol

    vwap.poly.delete()
    if showAnchoredVWAP
        polyline.new(vwap.points, false, false, line_color = dir < 0 ? R : S, line_width = xx)
    vwap.points.clear()

    for i = barsback to 0 by 1
        apt_i = aptSeries[i]
        alpha = alphaFromAPT(apt_i)
        pxv   = hlc3[i] * volume[i]
        v_i   = volume[i]
        p     := (1.0 - alpha) * p + alpha * pxv
        vol   := (1.0 - alpha) * vol + alpha * v_i
        vappe = vol > 0 ? p / vol : na
        vwap.points.push(chart.point.from_index(b - i, vappe))
        if i == 0
            vap := vappe

    vwap.poly := showAnchoredVWAP ? polyline.new(vwap.points, false, false, line_color = dir < 0 ? R : S, line_width = xx) : na

else
    apt_0 = aptSeries
    alpha = alphaFromAPT(apt_0)
    pxv = hlc3 * volume
    v0  = volume
    p   := (1.0 - alpha) * p + alpha * pxv
    vol := (1.0 - alpha) * vol + alpha * v0
    vap := vol > 0 ? p / vol : na

    vwap.poly.delete()
    vwap.points.push(chart.point.from_index(b, vap))
    vwap.poly := showAnchoredVWAP ? polyline.new(vwap.points, false, false, line_color = dir > 0 ? R : S, line_width = xx) : na
//~~ }

// ~~ Alignment Logic {
ribbonBullStack = showRibbon and not na(ribbon20) and not na(ribbon25) and not na(ribbon30) and not na(ribbon35) and not na(ribbon40) and not na(ribbon45) and not na(ribbon50) and ribbon20 > ribbon25 and ribbon25 > ribbon30 and ribbon30 > ribbon35 and ribbon35 > ribbon40 and ribbon40 > ribbon45 and ribbon45 > ribbon50
ribbonBearStack = showRibbon and not na(ribbon20) and not na(ribbon25) and not na(ribbon30) and not na(ribbon35) and not na(ribbon40) and not na(ribbon45) and not na(ribbon50) and ribbon20 < ribbon25 and ribbon25 < ribbon30 and ribbon30 < ribbon35 and ribbon35 < ribbon40 and ribbon40 < ribbon45 and ribbon45 < ribbon50

bullAlignment = ribbonBullStack and not na(vap) and not na(maValue) and maValue > ribbon20 and ribbon50 > vap
bearAlignment = ribbonBearStack and not na(vap) and not na(maValue) and maValue < ribbon20 and ribbon50 < vap

bgcolor(showAlignmentBg ? bullAlignment ? bullAlignColor : bearAlignment ? bearAlignColor : na : na, title="Alignment Background")
//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~}
