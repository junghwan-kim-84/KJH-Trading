//@version=5
indicator(title="MACD-Divergence-Tracker", shorttitle="MACD-Divergence-Tracker")

is_rising_confirmed(src, bars) =>
    rising = true
    for i = 0 to bars - 1
        rising := rising and src[i] > src[i + 1]
    rising

is_falling_confirmed(src, bars) =>
    falling = true
    for i = 0 to bars - 1
        falling := falling and src[i] < src[i + 1]
    falling

//Plot Inputs
res           = input.timeframe("",  "Indicator TimeFrame")
fast_length   = input.int(title="Fast Length", defval=12)
slow_length   = input.int(title="Slow Length", defval=26)
src           = input.source(title="Source", defval=close)
signal_length = input.int(title="Signal Smoothing", minval = 1, maxval = 999, defval = 9)
sma_source    = input.string(title="Oscillator MA Type", defval="EMA", options=["SMA", "EMA"])
sma_signal    = input.string(title="Signal Line MA Type", defval="EMA", options=["SMA", "EMA"])
// Show Plots T/F
show_macd     = input.bool(true, title="Show MACD Lines", group="Show Plots?", inline="SP10")
show_macd_LW  = input.int(2, minval=0, maxval=5, title = "MACD Width", group="Show Plots?", inline="SP11")
show_signal_LW= input.int(1, minval=0, maxval=5, title = "Signal Width", group="Show Plots?", inline="SP11")
show_Hist     = input.bool(true, title="Show Histogram", group="Show Plots?", inline="SP20")
show_hist_LW  = input.int(5, minval=0, maxval=5, title = "-- Width", group="Show Plots?", inline="SP20")
hist_scale    = input.float(3.0, minval=0.1, step=0.1, title="Histogram Scale", group="Show Plots?")
show_trend    = input.bool(true, title = "Show MACD Lines w/ Trend Color", group="Show Plots?", inline="SP30")
show_HB       = input.bool(false, title="Show Highlight Price Bars", group="Show Plots?", inline="SP40")
show_cross    = input.bool(false, title = "Show BackGround on Cross", group="Show Plots?", inline="SP50")
show_dots     = input.bool(true, title = "Show Circle on Cross", group="Show Plots?", inline="SP60")
show_dots_LW  = input.int(3, minval=0, maxval=5, title = "-- Width", group="Show Plots?", inline="SP60")

//show_trend    = input(true, title = "Colors MACD Lines w/ Trend Color", group="Show Plots?", inline="SP5")
// MACD Lines colors
col_macd      = input.color(#FF6D00, "MACD Line  ",  group="Color Settings", inline="CS1")
col_signal    = input.color(#2962FF, "Signal Line  ",  group="Color Settings", inline="CS1")
col_trnd_Up   = input.color(#4BAF4F, "Trend Up      ",  group="Color Settings", inline="CS2")
col_trnd_Dn   = input.color(#B71D1C, "Trend Down    ",  group="Color Settings", inline="CS2")
// Histogram Colors
col_grow_above = input.color(color.white, "Above   Grow",  group="Histogram Colors", inline="Hist10")
col_fall_above = input.color(#B8B8B8, "Fall",  group="Histogram Colors", inline="Hist10")
col_grow_below = input.color(color.white, "Below Grow",  group="Histogram Colors", inline="Hist20")
col_fall_below = input.color(#B8B8B8, "Fall",  group="Histogram Colors", inline="Hist20")
price_ma_length = input.int(title="Price MA Length", defval=9, minval=1, group="Divergence")
hist_smoothing_length = input.int(title="Histogram TRIX Smoothing", defval=3, minval=1, group="Divergence")
divergence_confirm_bars = input.int(title="Divergence Confirm Bars", defval=2, minval=1, group="Divergence")
divergence_atr_length = input.int(title="Divergence ATR Length", defval=14, minval=1, group="Divergence")
divergence_atr_filter = input.float(title="Divergence ATR Filter", defval=0.02, minval=0.0, step=0.01, group="Divergence")
// Alerts T/F Inputs
alert_Long    = input.bool(true, title = "MACD Cross Up", group = "Alerts", inline="Alert10")
alert_Short   = input.bool(true, title = "MACD Cross Dn", group = "Alerts", inline="Alert10")
alert_Long_A  = input.bool(false, title = "MACD Cross Up & > 0", group = "Alerts", inline="Alert20")
alert_Short_B = input.bool(false, title = "MACD Cross Dn & < 0", group = "Alerts", inline="Alert20")
// Calculating
fast_ma = request.security(syminfo.tickerid, res, sma_source == "SMA" ? ta.sma(src, fast_length) : ta.ema(src, fast_length))
slow_ma = request.security(syminfo.tickerid, res, sma_source == "SMA" ? ta.sma(src, slow_length) : ta.ema(src, slow_length))
macd = fast_ma - slow_ma
signal = request.security(syminfo.tickerid, res, sma_signal == "SMA" ? ta.sma(macd, signal_length) : ta.ema(macd, signal_length))
raw_hist = macd - signal
// Triple-smooth the histogram to get a TRIX-like response without changing the MACD or signal lines.
hist = ta.ema(ta.ema(ta.ema(raw_hist, hist_smoothing_length), hist_smoothing_length), hist_smoothing_length)
price_ma = request.security(syminfo.tickerid, res, ta.sma(close, price_ma_length))
price_atr = request.security(syminfo.tickerid, res, ta.atr(divergence_atr_length))
// MACD Trend and Cross Up/Down conditions
trend_up   = macd > signal
trend_dn   = macd < signal
cross_UP   = signal[1] >= macd[1] and signal < macd
cross_DN   = signal[1] <= macd[1] and signal > macd
cross_UP_A = (signal[1] >= macd[1] and signal < macd) and macd > 0
cross_DN_B = (signal[1] <= macd[1] and signal > macd) and macd < 0
ma_threshold = price_atr * divergence_atr_filter
has_ma_history = not na(price_ma[divergence_confirm_bars])
price_ma_move = has_ma_history ? price_ma - price_ma[divergence_confirm_bars] : 0.0
price_ma_up = has_ma_history and is_rising_confirmed(price_ma, divergence_confirm_bars) and price_ma_move > ma_threshold
price_ma_down = has_ma_history and is_falling_confirmed(price_ma, divergence_confirm_bars) and price_ma_move < -ma_threshold
bullish_divergence = trend_up and price_ma_down
bearish_divergence = trend_dn and price_ma_up
// Condition that changes Color of MACD Line if Show Trend is turned on..
trend_col = show_trend  and trend_up ? col_trnd_Up : trend_up ? col_macd : show_trend  and trend_dn ? col_trnd_Dn: trend_dn ? col_macd : na

//Var Statements for Histogram Color Change
var bool histA_IsUp = false
var bool histA_IsDown = false
var bool histB_IsDown = false
var bool histB_IsUp = false
histA_IsUp   := hist == hist[1] ? histA_IsUp[1] : hist > hist[1] and hist > 0
histA_IsDown := hist == hist[1] ? histA_IsDown[1] : hist < hist[1] and hist > 0
histB_IsDown := hist == hist[1] ? histB_IsDown[1] : hist < hist[1] and hist <= 0
histB_IsUp   := hist == hist[1] ? histB_IsUp[1] : hist > hist[1] and hist <= 0

default_hist_col = histA_IsUp ? col_grow_above : histA_IsDown ? col_fall_above : histB_IsDown ? col_grow_below : histB_IsUp ? col_fall_below : color.silver
bullish_div_hist_col = histA_IsUp ? #00C853 : histA_IsDown ? #2E7D32 : default_hist_col
bearish_div_hist_col = histB_IsDown ? #FF1744 : histB_IsUp ? #C62828 : default_hist_col
hist_col = bullish_divergence ? bullish_div_hist_col : bearish_divergence ? bearish_div_hist_col : default_hist_col
display_hist = hist * hist_scale

// Plot Statements
//Background Color
bgcolor(show_cross and cross_UP ? col_trnd_Up : na, editable=false)
bgcolor(show_cross and cross_DN ? col_trnd_Dn : na, editable=false)
//Highlight Price Bars
barcolor(show_HB and trend_up ? col_trnd_Up : na, title="Trend Up", offset = 0, editable=false)
barcolor(show_HB and trend_dn ? col_trnd_Dn : na, title="Trend Dn", offset = 0, editable=false)
//Regular Plots
plot(show_Hist ? display_hist : na, title="Histogram", style=plot.style_columns, color=color.new(hist_col ,0), linewidth=show_hist_LW, display=display.all - display.price_scale)
plot(show_macd ? signal : na, title="Signal", color=color.new(col_signal, 0),  style=plot.style_line ,linewidth=show_signal_LW)
plot(show_macd ? macd : na, title="MACD", color=color.new(trend_col, 0),  style=plot.style_line ,linewidth=show_macd_LW)
plot(0, title="0 Line", color=color.new(color.gray, 0), style=plot.style_line, linewidth=1, editable=false, display=display.all - display.price_scale)
plot(show_dots and cross_UP ? macd : na, title="Dots Up", color=color.new(col_trnd_Up, 0), style=plot.style_circles, linewidth=show_dots_LW, editable=false, display=display.all - display.price_scale)
plot(show_dots and cross_DN ? macd : na, title="Dots Down", color=color.new(col_trnd_Dn, 0), style=plot.style_circles, linewidth=show_dots_LW, editable=false, display=display.all - display.price_scale)

//Alerts
if alert_Long and cross_UP
    alert("Symbol = (" + syminfo.tickerid + ") TimeFrame = (" + timeframe.period + ") Current Price (" + str.tostring(close) + ") MACD Crosses Up.", alert.freq_once_per_bar_close)

if alert_Short and cross_DN
    alert("Symbol = (" + syminfo.tickerid + ") TimeFrame = (" + timeframe.period + ") Current Price (" + str.tostring(close) + ") MACD Crosses Down.", alert.freq_once_per_bar_close)
//Alerts - Stricter Condition - Only Alerts When MACD Crosses UP & MACD > 0 -- Crosses Down & MACD < 0
if alert_Long_A and cross_UP_A
    alert("Symbol = (" + syminfo.tickerid + ") TimeFrame = (" + timeframe.period + ") Current Price (" + str.tostring(close) + ") MACD > 0 And Crosses Up.", alert.freq_once_per_bar_close)

if alert_Short_B and cross_DN_B
    alert("Symbol = (" + syminfo.tickerid + ") TimeFrame = (" + timeframe.period + ") Current Price (" + str.tostring(close) + ") MACD < 0 And Crosses Down.", alert.freq_once_per_bar_close)

//End Code
