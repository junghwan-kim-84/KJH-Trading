//@version=6
indicator("abnormal-price-tracker-candles", overlay=true, format=format.volume, precision=0, max_labels_count=500)

// =========================
// MA Inputs
// =========================
maLength = input.int(9, title="이동평균 기간", minval=1)
src = input.source(close, title="평균 기준 가격")
colorAbove = input.color(color.rgb(144, 238, 144), title="종가가 이동평균선 위일 때 색상")
colorBelow = input.color(color.rgb(255, 160, 160), title="종가가 이동평균선 아래일 때 색상")
lineWidth = input.int(1, title="이동평균선 두께", minval=1, maxval=5)

// =========================
// cRSI Inputs
// =========================
domCycle = input.int(20, minval=10, title="cRSI Dominant Cycle Length")
vibration = input.int(10, minval=1, title="cRSI Vibration")
leveling = input.float(10.0, minval=1.0, maxval=50.0, title="cRSI Leveling (%)")
absoluteOB = input.float(70.0, title="절대 과매수 값")
absoluteOS = input.float(30.0, title="절대 과매도 값")
paintBars = input.bool(true, title="과매수/과매도 시 캔들 색상 변경")
overboughtColor = input.color(color.red, title="과매수 캔들 색상")
oversoldColor = input.color(color.aqua, title="과매도 캔들 색상")
showCRSIPlots = input.bool(false, title="cRSI / 밴드 플롯 표시")
enableRepeatingOBOSAlert = input.bool(true, title="과매수/과매도 반복 알림 사용")

// =========================
// Volume Inputs
// =========================
enableSmartVolume = input.bool(true, title="스마트 비정상 거래량 사용")
abnormalVolLookback = input.int(5, minval=1, title="매수/매도 거래량 평균 기준 봉 수")
abnormalVolMultiplier = input.float(0.4, minval=0.0, title="비정상 거래량 배수 기준")
useMAFilterForVolume = input.bool(true, title="거래량 시그널에 MA 필터 적용")
useCRSIFilterForVolume = input.bool(false, title="거래량 시그널에 cRSI 필터 적용")
showVolumeMA = input.bool(false, title="매수/매도 거래량 평균선 표시")
buyVolumeMAColor = input.color(color.teal, title="매수 거래량 평균선 색상")
sellVolumeMAColor = input.color(color.red, title="매도 거래량 평균선 색상")

// =========================
// RSI Divergence Inputs
// =========================
showRSIDivergence = input.bool(true, title="RSI 다이버전스 표시")
rsiDivLength = input.int(12, title="RSI 기간")
lbR = input.int(5, title="Pivot Right")
lbL = input.int(5, title="Pivot Left")
rangeUpper = input.int(60, title="최대 탐색 범위")
rangeLower = input.int(5, title="최소 탐색 범위")
showRegularBullDiv = input.bool(true, title="일반 강세 다이버전스")
showRegularBearDiv = input.bool(true, title="일반 약세 다이버전스")

// =========================
// Background Zone Inputs
// =========================
showBgZone = input.bool(true, title="배경 구간 표시")
useDivForBg = input.bool(true, title="다이버전스 기준 배경 사용")
useCandleForBg = input.bool(true, title="과매수/과매도 캔들 기준 배경 사용")
setupLookbackBars = input.int(36, minval=1, title="기준 신호 이후 추적 봉 수")
atrLength = input.int(14, minval=1, title="ATR 기간")
atrMultiplier = input.float(0.8, minval=0.1, step=0.1, title="ATR 과도 이동 배수")
strongBgAtrMultiplier = input.float(1.4, minval=1.0, step=0.1, title="강한 배경 판정 ATR 배수")
rsiMoveLimit = input.float(15.0, minval=0.1, step=0.1, title="RSI 추가 이동 제한값")
useCRSIFilterForBg = input.bool(true, title="배경 구간에 cRSI 필터 적용")
useVolumeFilterForBg = input.bool(false, title="배경 구간에 거래량 필터 적용")

bullBgBaseColor = input.color(color.green, title="강세 배경 색상")
bullBgStrongColor = input.color(color.blue, title="강한 강세 배경 색상")
bearBgBaseColor = input.color(color.orange, title="약세 배경 색상")
bearBgStrongColor = input.color(color.red, title="강한 약세 배경 색상")

bgTransparency = input.int(62, minval=0, maxval=100, title="배경 투명도")

// =========================
// L/S Entry Signal Inputs
// =========================
compositeGroup = "L/S 진입 신호"
showCompositeLabels = input.bool(true, title="L/S 진입 라벨 표시", group=compositeGroup)
setupValidityBars = input.int(6, title="변곡 후보 유효시간", minval=1, maxval=20, group=compositeGroup)
compositeLookbackBars = input.int(3, title="진입 확인 봉 수", minval=1, maxval=20, group=compositeGroup)
compositeMinSignals = input.int(2, title="변곡점 축 최소 충족 수", minval=2, maxval=3, group=compositeGroup)
entryVolumePressureRatio = input.float(1.2, title="진입 거래량 압력 비율", minval=1.0, step=0.05, group=compositeGroup)
buyCompositeColor = input.color(color.rgb(46, 125, 50), title="L 라벨 색상", group=compositeGroup, inline="ls")
sellCompositeColor = input.color(color.rgb(198, 40, 40), title="S 라벨 색상", group=compositeGroup, inline="ls")
compositeLabelAtrOffset = input.float(0.35, title="L/S 라벨 ATR 간격", minval=0.1, step=0.05, group=compositeGroup)
entryMaxDistanceFromMAAtr = input.float(1.2, title="추격 진입 제한 MA 거리(ATR)", minval=0.1, step=0.1, group=compositeGroup)
entryMaxMoveFromSetupAtr = input.float(1.8, title="추격 진입 제한 변곡점 이탈(ATR)", minval=0.1, step=0.1, group=compositeGroup)
sameDirectionCooldownBars = input.int(8, title="같은 방향 재발신 제한 봉 수", minval=1, maxval=100, group=compositeGroup)

// =========================
// Volume Pressure Tracker Inputs
// =========================
volumeCompositeGroup = "거래량 압력 종합 신호"
vpLength = input.int(20, title="거래량 비교 봉 수", minval=1, group=volumeCompositeGroup)
vpMultiplier = input.float(1.0, title="거래량 비정상 배수", minval=0, group=volumeCompositeGroup)
vpSwingPeriod = input.int(20, title="거래량 정렬 Swing Period", minval=2, group=volumeCompositeGroup)
vpBaseAPT = input.float(20.0, title="거래량 정렬 Adaptive Price Tracking", minval=1, step=1, group=volumeCompositeGroup)
vpUseAdapt = input.bool(false, title="거래량 정렬 APT 적응 사용", group=volumeCompositeGroup)
vpVolBias = input.float(10.0, title="거래량 정렬 Volatility Bias", minval=0.1, step=0.1, group=volumeCompositeGroup)
vpBasePeriods = input.int(20, minval=1, title="거래량 정렬 Base Line Length", group=volumeCompositeGroup)
vpMaLength = input.int(5, title="거래량 정렬 MA Length", minval=1, group=volumeCompositeGroup)

// =========================
// Helper Signal Inputs
// =========================
helperCompositeGroup = "보조 종합 신호"
helperMfiLength = input.int(14, minval=1, title="MFI Length", group=helperCompositeGroup)
helperGapThreshold = input.float(18.0, minval=1.0, title="Gap Background Threshold", group=helperCompositeGroup)
helperWeakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold", group=helperCompositeGroup)
helperStrongGapThreshold = input.float(14.0, minval=0.0, title="Strong Gap Threshold", group=helperCompositeGroup)
helperBearishZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bearish Risk cRSI Zone", group=helperCompositeGroup)
helperBullishZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bullish Risk cRSI Zone", group=helperCompositeGroup)
helperVolumeAvgLength = input.int(3, minval=1, title="보조 거래량 평균 길이", group=helperCompositeGroup)
helperVolumeMultiplier = input.float(1.0, minval=0.1, step=0.1, title="보조 거래량 배수", group=helperCompositeGroup)
helperTrendLength = input.int(5, minval=2, title="보조 추세 길이", group=helperCompositeGroup)
helperPriceStretchThreshold = input.float(1.5, minval=0.1, step=0.1, title="Price Stretch (%)", group=helperCompositeGroup)
helperUseGapFade = input.bool(true, title="Use Gap Fade Condition", group=helperCompositeGroup)
helperGapFadeLookback = input.int(1, minval=1, maxval=5, title="Gap Fade Lookback", group=helperCompositeGroup)
helperMinStrength = input.int(1, minval=1, maxval=3, title="보조 최소 강도", group=helperCompositeGroup)

donchian(len) =>
    math.avg(ta.lowest(len), ta.highest(len))

alphaFromAPT(apt) =>
    decay = math.exp(-math.log(2.0) / math.max(1.0, apt))
    1.0 - decay

recentSignal(cond, lookbackBars) =>
    bars = ta.barssince(cond)
    bars >= 0 and bars <= lookbackBars

// =========================
// Moving Average
// =========================
ma = ta.sma(src, maLength)
maColor = close >= ma ? colorAbove : colorBelow
plot(ma, title="이동평균선", color=maColor, linewidth=lineWidth, display=display.all - display.price_scale)

// =========================
// cRSI Calculation
// =========================
cycleLen = math.max(1, int(domCycle / 2))
cyclicMemory = domCycle * 2
torque = 2.0 / (vibration + 1.0)
phasingLag = int((vibration - 1) / 2.0)

up = ta.rma(math.max(ta.change(close), 0), cycleLen)
down = ta.rma(-math.min(ta.change(close), 0), cycleLen)
rsi = down == 0 ? 100.0 : up == 0 ? 0.0 : 100.0 - 100.0 / (1.0 + up / down)

var float crsi = na
crsi := torque * (2.0 * rsi - nz(rsi[phasingLag])) + (1.0 - torque) * nz(crsi[1])

// =========================
// Dynamic Band Calculation
// =========================
float lmax = -999999.0
float lmin = 999999.0

for i = 0 to cyclicMemory - 1
    val = nz(crsi[i])
    if val > lmax
        lmax := val
    if val < lmin
        lmin := val

mstep = (lmax - lmin) / 100.0
aperc = leveling / 100.0

float db = na
for steps = 0 to 100
    testValue = lmin + mstep * steps
    below = 0.0
    for m = 0 to cyclicMemory - 1
        below += crsi[m] < testValue ? 1 : 0
    ratio = below / cyclicMemory
    if ratio >= aperc
        db := testValue
        break

float ub = na
for steps = 0 to 100
    testValue = lmax - mstep * steps
    above = 0.0
    for m = 0 to cyclicMemory - 1
        above += crsi[m] >= testValue ? 1 : 0
    ratio = above / cyclicMemory
    if ratio >= aperc
        ub := testValue
        break

// =========================
// Confirmed OB / OS
// =========================
isOverbought = crsi >= absoluteOB
isOversold = crsi <= absoluteOS

barCol = isOverbought ? overboughtColor : isOversold ? oversoldColor : na
barcolor(paintBars ? barCol : na)

// =========================
// Buy / Sell Volume
// =========================
rangeValue = high - low
buyVolume = rangeValue == 0 ? 0.0 : volume * (close - low) / rangeValue
sellVolume = rangeValue == 0 ? 0.0 : volume * (high - close) / rangeValue

avgBuyVolume = ta.sma(buyVolume, abnormalVolLookback)
avgSellVolume = ta.sma(sellVolume, abnormalVolLookback)

abnormalBuyVolume = buyVolume > avgBuyVolume * (1 + abnormalVolMultiplier)
abnormalSellVolume = sellVolume > avgSellVolume * (1 + abnormalVolMultiplier)

// =========================
// Smart Volume Conditions
// =========================
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
bodySize = math.abs(close - open)

isBullPressureBar = close > open or lowerWick > bodySize
isBearPressureBar = close < open or upperWick > bodySize

maBullFilter = not useMAFilterForVolume or close >= ma
maBearFilter = not useMAFilterForVolume or high >= ma

crsiBullFilter = not useCRSIFilterForVolume or isOversold
crsiBearFilter = not useCRSIFilterForVolume or isOverbought

bullSmartVolumeSignal = enableSmartVolume and abnormalBuyVolume and isBullPressureBar and maBullFilter and crsiBullFilter
bearSmartVolumeSignal = enableSmartVolume and abnormalSellVolume and isBearPressureBar and maBearFilter and crsiBearFilter

// =========================
// RSI Divergence Calculation
// =========================
osc = ta.rsi(close, rsiDivLength)

plFound = not na(ta.pivotlow(osc, lbL, lbR))
phFound = not na(ta.pivothigh(osc, lbL, lbR))

_inRange(cond) =>
    bars = ta.barssince(cond == true)
    rangeLower <= bars and bars <= rangeUpper

inRangePl = _inRange(plFound[1])
inRangePh = _inRange(phFound[1])

oscHL = osc[lbR] > ta.valuewhen(plFound, osc[lbR], 1) and inRangePl
oscLH = osc[lbR] < ta.valuewhen(phFound, osc[lbR], 1) and inRangePh

priceLL = low[lbR] < ta.valuewhen(plFound, low[lbR], 1)
priceHH = high[lbR] > ta.valuewhen(phFound, high[lbR], 1)

bullDiv = showRSIDivergence and showRegularBullDiv and plFound and priceLL and oscHL
bearDiv = showRSIDivergence and showRegularBearDiv and phFound and priceHH and oscLH

regularBullDiv = showRSIDivergence and showRegularBullDiv and plFound and priceLL and oscHL
regularBearDiv = showRSIDivergence and showRegularBearDiv and phFound and priceHH and oscLH

// =========================
// Divergence Markers
// =========================
plotshape(regularBullDiv, offset=-lbR, title="일반 강세 다이버전스", style=shape.triangleup, location=location.belowbar, color=oversoldColor, size=size.small)
plotshape(regularBearDiv, offset=-lbR, title="일반 약세 다이버전스", style=shape.triangledown, location=location.abovebar, color=overboughtColor, size=size.small)

// =========================
// ATR
// =========================
atr = ta.atr(atrLength)
signalAtr = ta.atr(50)
signalAtrAvg = ta.rma(signalAtr, 50)
signalVolatilityRatio = signalAtrAvg > 0 ? signalAtr / signalAtrAvg : 1.0

// =========================
// Volume Pressure Tracker Composite Logic
// =========================
vpBar = bar_index

var float vpPh = na
var float vpPl = na
var int vpPhBar = 0
var int vpPlBar = 0
var float vpP = hlc3 * volume
var float vpVol = volume
var float vpVap = na

vpPh := ta.highestbars(high, vpSwingPeriod) == 0 ? high : vpPh
vpPl := ta.lowestbars(low, vpSwingPeriod) == 0 ? low : vpPl
vpPhBar := ta.highestbars(high, vpSwingPeriod) == 0 ? vpBar : vpPhBar
vpPlBar := ta.lowestbars(low, vpSwingPeriod) == 0 ? vpBar : vpPlBar
vpDir = vpPhBar > vpPlBar ? 1 : -1

vpAptRaw = vpUseAdapt ? vpBaseAPT / math.pow(signalVolatilityRatio, vpVolBias) : vpBaseAPT
vpAptClamped = math.max(5.0, math.min(300.0, vpAptRaw))
vpAptSeries = math.round(vpAptClamped)

if vpDir != vpDir[1]
    vpAnchorBar = vpDir > 0 ? vpPlBar : vpPhBar
    vpAnchorPrice = vpDir > 0 ? vpPl : vpPh
    vpBarsback = vpBar - vpAnchorBar
    vpP := vpAnchorPrice * volume[vpBarsback]
    vpVol := volume[vpBarsback]
    vpVap := vpVol > 0 ? vpP / vpVol : na

    for i = vpBarsback to 0 by 1
        alpha = alphaFromAPT(vpAptSeries[i])
        pxv = hlc3[i] * volume[i]
        vpP := (1.0 - alpha) * vpP + alpha * pxv
        vpVol := (1.0 - alpha) * vpVol + alpha * volume[i]
        vappe = vpVol > 0 ? vpP / vpVol : na
        if i == 0
            vpVap := vappe
else
    alpha = alphaFromAPT(vpAptSeries)
    pxv = hlc3 * volume
    vpP := (1.0 - alpha) * vpP + alpha * pxv
    vpVol := (1.0 - alpha) * vpVol + alpha * volume
    vpVap := vpVol > 0 ? vpP / vpVol : na

vpBaseLine = donchian(vpBasePeriods)
vpMaValue = ta.sma(close, vpMaLength)
vpBullAlignment = not na(vpVap) and not na(vpBaseLine) and not na(vpMaValue) and vpMaValue > vpBaseLine and vpBaseLine > vpVap
vpBearAlignment = not na(vpVap) and not na(vpBaseLine) and not na(vpMaValue) and vpMaValue < vpBaseLine and vpBaseLine < vpVap
vpAvgVolume = ta.sma(volume, vpLength)
vpAbnormalVolume = volume > vpAvgVolume * (1 + vpMultiplier)
vpBullPressureSignal = vpBullAlignment and vpAbnormalVolume and buyVolume > sellVolume
vpBearPressureSignal = vpBearAlignment and vpAbnormalVolume and sellVolume > buyVolume

// =========================
// Helper Signal Composite Logic
// =========================
helperOverboughtLevel = 80.0
helperOversoldLevel = 20.0
helperMfi = ta.mfi(hlc3, helperMfiLength)

helperGap = math.abs(crsi - helperMfi)
helperBearishGapBg = crsi > helperMfi and helperGap >= helperGapThreshold
helperBullishGapBg = helperMfi > crsi and helperGap >= helperGapThreshold

helperVolAvg = ta.sma(volume, helperVolumeAvgLength)
helperVolumeOkay = volume > helperVolAvg * helperVolumeMultiplier
helperPriceEma = ta.ema(close, helperTrendLength)
helperPriceStretchPct = helperPriceEma != 0 ? (close - helperPriceEma) / helperPriceEma * 100.0 : 0.0
helperPriceExtendedUp = close > close[helperTrendLength] and helperPriceStretchPct >= helperPriceStretchThreshold
helperPriceExtendedDown = close < close[helperTrendLength] and helperPriceStretchPct <= -helperPriceStretchThreshold

helperBearishGap = crsi - helperMfi
helperBullishGap = helperMfi - crsi
helperBearishGapScore = helperBearishGap > helperStrongGapThreshold ? 2 : helperBearishGap > helperWeakGapThreshold ? 1 : 0
helperBullishGapScore = helperBullishGap > helperStrongGapThreshold ? 2 : helperBullishGap > helperWeakGapThreshold ? 1 : 0

helperBearishZonePass = crsi >= helperBearishZone or (not na(ub) and crsi >= ub)
helperBullishZonePass = crsi <= helperBullishZone or (not na(db) and crsi <= db)
helperBearishGapFade = helperBearishGap < helperBearishGap[helperGapFadeLookback]
helperBullishGapFade = helperBullishGap < helperBullishGap[helperGapFadeLookback]
helperCrsiTurningDown = crsi < crsi[1]
helperCrsiTurningUp = crsi > crsi[1]
helperMfiTurningDown = helperMfi < helperMfi[1]
helperMfiTurningUp = helperMfi > helperMfi[1]

helperBearishRiskScore = 0
helperBearishRiskScore += helperBearishGapBg ? 1 : 0
helperBearishRiskScore += helperBearishGapScore
helperBearishRiskScore += helperPriceExtendedUp ? 1 : 0
helperBearishRiskScore += helperVolumeOkay ? 1 : 0
helperBearishRiskScore += helperBearishZonePass ? 1 : 0
helperBearishRiskScore += ((helperUseGapFade and helperBearishGapFade) or (not helperUseGapFade and helperCrsiTurningDown)) ? 1 : 0
helperBearishRiskScore += (helperCrsiTurningDown or helperMfiTurningDown) ? 1 : 0

helperBullishRiskScore = 0
helperBullishRiskScore += helperBullishGapBg ? 1 : 0
helperBullishRiskScore += helperBullishGapScore
helperBullishRiskScore += helperPriceExtendedDown ? 1 : 0
helperBullishRiskScore += helperVolumeOkay ? 1 : 0
helperBullishRiskScore += helperBullishZonePass ? 1 : 0
helperBullishRiskScore += ((helperUseGapFade and helperBullishGapFade) or (not helperUseGapFade and helperCrsiTurningUp)) ? 1 : 0
helperBullishRiskScore += (helperCrsiTurningUp or helperMfiTurningUp) ? 1 : 0

helperBearishRiskStrength = helperBearishRiskScore >= 7 ? 3 : helperBearishRiskScore >= 5 ? 2 : helperBearishRiskScore >= 4 ? 1 : 0
helperBullishRiskStrength = helperBullishRiskScore >= 7 ? 3 : helperBullishRiskScore >= 5 ? 2 : helperBullishRiskScore >= 4 ? 1 : 0

helperBearishRiskRaw = helperBearishGapBg and helperBearishRiskStrength >= helperMinStrength and helperBullishRiskStrength == 0
helperBullishRiskRaw = helperBullishGapBg and helperBullishRiskStrength >= helperMinStrength and helperBearishRiskStrength == 0

helperBearishSignal = helperBearishRiskRaw and helperMfi > helperOversoldLevel
helperBullishSignal = helperBullishRiskRaw and helperMfi < helperOverboughtLevel

// =========================
// Background Trigger Signals
// =========================
bullDivTrigger = bullDiv
bearDivTrigger = bearDiv
bullCandleTrigger = isOversold
bearCandleTrigger = isOverbought

// =========================
// Divergence-based Background Logic
// =========================
bullDivBars = ta.barssince(bullDivTrigger)
bearDivBars = ta.barssince(bearDivTrigger)

hasBullDiv = bullDivBars >= 0 and bullDivBars <= setupLookbackBars
hasBearDiv = bearDivBars >= 0 and bearDivBars <= setupLookbackBars

bullDivRefClose = ta.valuewhen(bullDivTrigger, close, 0)
bullDivRefRsi = ta.valuewhen(bullDivTrigger, osc, 0)
bullDivRefAtr = ta.valuewhen(bullDivTrigger, atr, 0)

bearDivRefClose = ta.valuewhen(bearDivTrigger, close, 0)
bearDivRefRsi = ta.valuewhen(bearDivTrigger, osc, 0)
bearDivRefAtr = ta.valuewhen(bearDivTrigger, atr, 0)

bullDivPriceMove = hasBullDiv and not na(bullDivRefClose) ? bullDivRefClose - close : na
bullDivRsiMove = hasBullDiv and not na(bullDivRefRsi) ? bullDivRefRsi - osc : na
bullDivAtrNeed = hasBullDiv and not na(bullDivRefAtr) ? bullDivRefAtr * atrMultiplier : na

bearDivPriceMove = hasBearDiv and not na(bearDivRefClose) ? close - bearDivRefClose : na
bearDivRsiMove = hasBearDiv and not na(bearDivRefRsi) ? osc - bearDivRefRsi : na
bearDivAtrNeed = hasBearDiv and not na(bearDivRefAtr) ? bearDivRefAtr * atrMultiplier : na

bullBgFromDiv = hasBullDiv and bullDivBars > 0 and not na(bullDivPriceMove) and not na(bullDivRsiMove) and not na(bullDivAtrNeed) and bullDivPriceMove >= bullDivAtrNeed and bullDivRsiMove <= rsiMoveLimit
bearBgFromDiv = hasBearDiv and bearDivBars > 0 and not na(bearDivPriceMove) and not na(bearDivRsiMove) and not na(bearDivAtrNeed) and bearDivPriceMove >= bearDivAtrNeed and bearDivRsiMove <= rsiMoveLimit

// =========================
// Candle-based Background Logic
// =========================
bullCandleBars = ta.barssince(bullCandleTrigger)
bearCandleBars = ta.barssince(bearCandleTrigger)

hasBullCandle = bullCandleBars >= 0 and bullCandleBars <= setupLookbackBars
hasBearCandle = bearCandleBars >= 0 and bearCandleBars <= setupLookbackBars

bullCandleRefClose = ta.valuewhen(bullCandleTrigger, close, 0)
bullCandleRefRsi = ta.valuewhen(bullCandleTrigger, osc, 0)
bullCandleRefAtr = ta.valuewhen(bullCandleTrigger, atr, 0)

bearCandleRefClose = ta.valuewhen(bearCandleTrigger, close, 0)
bearCandleRefRsi = ta.valuewhen(bearCandleTrigger, osc, 0)
bearCandleRefAtr = ta.valuewhen(bearCandleTrigger, atr, 0)

bullCandlePriceMove = hasBullCandle and not na(bullCandleRefClose) ? bullCandleRefClose - close : na
bullCandleRsiMove = hasBullCandle and not na(bullCandleRefRsi) ? bullCandleRefRsi - osc : na
bullCandleAtrNeed = hasBullCandle and not na(bullCandleRefAtr) ? bullCandleRefAtr * atrMultiplier : na

bearCandlePriceMove = hasBearCandle and not na(bearCandleRefClose) ? close - bearCandleRefClose : na
bearCandleRsiMove = hasBearCandle and not na(bearCandleRefRsi) ? osc - bearCandleRefRsi : na
bearCandleAtrNeed = hasBearCandle and not na(bearCandleRefAtr) ? bearCandleRefAtr * atrMultiplier : na

bullBgFromCandle = hasBullCandle and bullCandleBars > 0 and not na(bullCandlePriceMove) and not na(bullCandleRsiMove) and not na(bullCandleAtrNeed) and bullCandlePriceMove >= bullCandleAtrNeed and bullCandleRsiMove <= rsiMoveLimit
bearBgFromCandle = hasBearCandle and bearCandleBars > 0 and not na(bearCandlePriceMove) and not na(bearCandleRsiMove) and not na(bearCandleAtrNeed) and bearCandlePriceMove >= bearCandleAtrNeed and bearCandleRsiMove <= rsiMoveLimit

// =========================
// Background Filters
// =========================
bullBgCRSIFilter = not useCRSIFilterForBg or isOversold or (not na(db) and crsi <= db)
bearBgCRSIFilter = not useCRSIFilterForBg or isOverbought or (not na(ub) and crsi >= ub)

bullBgVolumeFilter = not useVolumeFilterForBg or abnormalBuyVolume or bullSmartVolumeSignal or volume > ta.sma(volume, 20) * 1.05
bearBgVolumeFilter = not useVolumeFilterForBg or abnormalSellVolume or bearSmartVolumeSignal or volume > ta.sma(volume, 20) * 1.05

bullBgFromDiv := bullBgFromDiv and bullBgCRSIFilter and bullBgVolumeFilter and useDivForBg and showBgZone
bearBgFromDiv := bearBgFromDiv and bearBgCRSIFilter and bearBgVolumeFilter and useDivForBg and showBgZone
bullBgFromCandle := bullBgFromCandle and bullBgCRSIFilter and bullBgVolumeFilter and useCandleForBg and showBgZone
bearBgFromCandle := bearBgFromCandle and bearBgCRSIFilter and bearBgVolumeFilter and useCandleForBg and showBgZone

// =========================
// Background Strength
// =========================
bullBgStrongByDiv = bullBgFromDiv and not na(bullDivPriceMove) and not na(bullDivRefAtr) and bullDivPriceMove >= bullDivRefAtr * strongBgAtrMultiplier
bullBgStrongByCandle = bullBgFromCandle and not na(bullCandlePriceMove) and not na(bullCandleRefAtr) and bullCandlePriceMove >= bullCandleRefAtr * strongBgAtrMultiplier
bearBgStrongByDiv = bearBgFromDiv and not na(bearDivPriceMove) and not na(bearDivRefAtr) and bearDivPriceMove >= bearDivRefAtr * strongBgAtrMultiplier
bearBgStrongByCandle = bearBgFromCandle and not na(bearCandlePriceMove) and not na(bearCandleRefAtr) and bearCandlePriceMove >= bearCandleRefAtr * strongBgAtrMultiplier

bullBgStrong = (bullBgFromDiv and bullBgFromCandle) or bullBgStrongByDiv or bullBgStrongByCandle
bearBgStrong = (bearBgFromDiv and bearBgFromCandle) or bearBgStrongByDiv or bearBgStrongByCandle

bullBgOn = bullBgFromDiv or bullBgFromCandle
bearBgOn = bearBgFromDiv or bearBgFromCandle

bullBgColor = bullBgStrong ? color.new(bullBgStrongColor, bgTransparency) : bullBgOn ? color.new(bullBgBaseColor, bgTransparency) : na
bearBgColor = bearBgStrong ? color.new(bearBgStrongColor, bgTransparency) : bearBgOn ? color.new(bearBgBaseColor, bgTransparency) : na

finalBgColor = not na(bullBgColor) ? bullBgColor : not na(bearBgColor) ? bearBgColor : na
bgcolor(finalBgColor, title="강세/약세 배경 구간")

// =========================
// L/S Entry Signals
// =========================
bullVolumeRatioPass = sellVolume == 0 ? buyVolume > 0 : buyVolume >= sellVolume * entryVolumePressureRatio
bearVolumeRatioPass = buyVolume == 0 ? sellVolume > 0 : sellVolume >= buyVolume * entryVolumePressureRatio

helperBullGapContracting = recentSignal(helperBullishGap > 0 and helperBullishGap < helperBullishGap[helperGapFadeLookback], compositeLookbackBars)
helperBearGapContracting = recentSignal(helperBearishGap > 0 and helperBearishGap < helperBearishGap[helperGapFadeLookback], compositeLookbackBars)

candleBullSignal = recentSignal(isOversold or regularBullDiv or bullBgOn or bullBgStrong, setupValidityBars)
candleBearSignal = recentSignal(isOverbought or regularBearDiv or bearBgOn or bearBgStrong, setupValidityBars)
volumeBullSignal = recentSignal((vpBullAlignment and vpAbnormalVolume and bullVolumeRatioPass) or (bullSmartVolumeSignal and bullVolumeRatioPass), setupValidityBars)
volumeBearSignal = recentSignal((vpBearAlignment and vpAbnormalVolume and bearVolumeRatioPass) or (bearSmartVolumeSignal and bearVolumeRatioPass), setupValidityBars)
helperBullSignal = recentSignal(helperBullishSignal or (helperBullishGapBg and helperBullishRiskStrength >= math.max(helperMinStrength, 2) and helperBullishZonePass), setupValidityBars) and helperBullGapContracting
helperBearSignal = recentSignal(helperBearishSignal or (helperBearishGapBg and helperBearishRiskStrength >= math.max(helperMinStrength, 2) and helperBearishZonePass), setupValidityBars) and helperBearGapContracting

buyCompositeScore = (candleBullSignal ? 1 : 0) + (volumeBullSignal ? 1 : 0) + (helperBullSignal ? 1 : 0)
sellCompositeScore = (candleBearSignal ? 1 : 0) + (volumeBearSignal ? 1 : 0) + (helperBearSignal ? 1 : 0)

buySetupReady = buyCompositeScore >= compositeMinSignals and buyCompositeScore > sellCompositeScore
sellSetupReady = sellCompositeScore >= compositeMinSignals and sellCompositeScore > buyCompositeScore

buySetupStart = buySetupReady and not buySetupReady[1]
sellSetupStart = sellSetupReady and not sellSetupReady[1]

recentBuySetup = recentSignal(buySetupStart, compositeLookbackBars)
recentSellSetup = recentSignal(sellSetupStart, compositeLookbackBars)

var float buySetupLow = na
var float sellSetupHigh = na
var int lastLongSignalBar = na
var int lastShortSignalBar = na

if sellSetupReady
    lastLongSignalBar := na

if buySetupReady
    lastShortSignalBar := na

if buySetupStart
    buySetupLow := low
else if recentBuySetup
    buySetupLow := na(buySetupLow) ? low : math.min(buySetupLow, low)
else
    buySetupLow := na

if sellSetupStart
    sellSetupHigh := high
else if recentSellSetup
    sellSetupHigh := na(sellSetupHigh) ? high : math.max(sellSetupHigh, high)
else
    sellSetupHigh := na

longCrsiRecovery = ta.crossover(crsi, absoluteOS) or (crsi > crsi[1] and crsi[1] <= crsi[2] and crsi <= absoluteOS + 10)
shortCrsiRecovery = ta.crossunder(crsi, absoluteOB) or (crsi < crsi[1] and crsi[1] >= crsi[2] and crsi >= absoluteOB - 10)

longReversalBar = close > high[1]
shortReversalBar = close < low[1]

longEntryConfirm = longCrsiRecovery or longReversalBar
shortEntryConfirm = shortCrsiRecovery or shortReversalBar

longAntiChaseOk = (na(atr) or close <= ma + atr * entryMaxDistanceFromMAAtr) and (na(atr) or na(buySetupLow) or close - buySetupLow <= atr * entryMaxMoveFromSetupAtr)
shortAntiChaseOk = (na(atr) or close >= ma - atr * entryMaxDistanceFromMAAtr) and (na(atr) or na(sellSetupHigh) or sellSetupHigh - close <= atr * entryMaxMoveFromSetupAtr)

longCooldownActive = not na(lastLongSignalBar) and bar_index - lastLongSignalBar <= sameDirectionCooldownBars and not sellSetupReady
shortCooldownActive = not na(lastShortSignalBar) and bar_index - lastShortSignalBar <= sameDirectionCooldownBars and not buySetupReady

buyCompositeRaw = barstate.isconfirmed and recentBuySetup and longEntryConfirm and longAntiChaseOk and not sellSetupReady
sellCompositeRaw = barstate.isconfirmed and recentSellSetup and shortEntryConfirm and shortAntiChaseOk and not buySetupReady

buyCompositeSignal = buyCompositeRaw and not buyCompositeRaw[1] and not longCooldownActive
sellCompositeSignal = sellCompositeRaw and not sellCompositeRaw[1] and not shortCooldownActive

if buyCompositeSignal
    lastLongSignalBar := bar_index
    lastShortSignalBar := na

if sellCompositeSignal
    lastShortSignalBar := bar_index
    lastLongSignalBar := na

buyCompositeLabelY = na(atr) ? low : low - atr * compositeLabelAtrOffset
sellCompositeLabelY = na(atr) ? high : high + atr * compositeLabelAtrOffset

if showCompositeLabels and buyCompositeSignal
    label.new(bar_index, buyCompositeLabelY, text="L", style=label.style_label_up, color=buyCompositeColor, textcolor=color.white, size=size.normal)

if showCompositeLabels and sellCompositeSignal
    label.new(bar_index, sellCompositeLabelY, text="S", style=label.style_label_down, color=sellCompositeColor, textcolor=color.white, size=size.normal)

// =========================
// Entry Alerts
// =========================
overboughtEnter = ta.crossover(crsi, absoluteOB)
oversoldEnter = ta.crossunder(crsi, absoluteOS)

repeatOverboughtAlert = barstate.isconfirmed and enableRepeatingOBOSAlert and isOverbought
repeatOversoldAlert = barstate.isconfirmed and enableRepeatingOBOSAlert and isOversold

bullBgAlert = barstate.isconfirmed and bullBgOn
bearBgAlert = barstate.isconfirmed and bearBgOn

bullBgStrongAlert = barstate.isconfirmed and bullBgStrong
bearBgStrongAlert = barstate.isconfirmed and bearBgStrong

alertcondition(oversoldEnter, title="매수 후보 신호 - 과매도 시작", message="매수 후보 신호 - 과매도 시작")
alertcondition(overboughtEnter, title="매도 후보 신호 - 과매수 시작", message="매도 후보 신호 - 과매수 시작")

alertcondition(repeatOversoldAlert, title="매수 후보 유지 - 과매도 계속", message="매수 후보 유지 - 과매도 계속")
alertcondition(repeatOverboughtAlert, title="매도 후보 유지 - 과매수 계속", message="매도 후보 유지 - 과매수 계속")

alertcondition(regularBullDiv, title="매수 후보 신호 - 하락 힘 약해짐", message="매수 후보 신호 - 하락 힘 약해짐")
alertcondition(regularBearDiv, title="매도 후보 신호 - 상승 힘 약해짐", message="매도 후보 신호 - 상승 힘 약해짐")

alertcondition(bullBgOn, title="매수 감시 구간 진입", message="매수 감시 구간 진입")
alertcondition(bearBgOn, title="매도 감시 구간 진입", message="매도 감시 구간 진입")

alertcondition(bullBgStrong, title="매수 감시 구간 강화", message="매수 감시 구간 강화")
alertcondition(bearBgStrong, title="매도 감시 구간 강화", message="매도 감시 구간 강화")
alertcondition(buyCompositeSignal, title="롱 진입 신호 - L", message="롱 진입 신호 - L")
alertcondition(sellCompositeSignal, title="숏 진입 신호 - S", message="숏 진입 신호 - S")

// =========================
// Optional Plots
// =========================
plot(showCRSIPlots ? crsi : na, title="cRSI", color=color.fuchsia)
plot(showCRSIPlots ? ub : na, title="cRSI 상단 밴드", color=color.new(color.red, 0))
plot(showCRSIPlots ? db : na, title="cRSI 하단 밴드", color=color.new(color.aqua, 0))
plot(showVolumeMA ? avgBuyVolume : na, title="매수 거래량 평균선", color=buyVolumeMAColor)
plot(showVolumeMA ? avgSellVolume : na, title="매도 거래량 평균선", color=sellVolumeMAColor)
