//@version=6
indicator("Volume-Pressure-Tracker", format=format.volume, precision=0)

// =========================
// Buy / Sell Volume 계산
// =========================
buyVolume  = high == low ? 0 : volume * (close - low) / (high - low)
sellVolume = high == low ? 0 : volume * (high - close) / (high - low)

// =========================
// 색상 설정
// =========================
normalBuyColor     = input.color(color.white, "정상 Buy 색상", group="Volume Colors")
normalSellColor    = input.color(color.gray, "정상 Sell 색상", group="Volume Colors")
abnormalBuyColor   = input.color(color.lime, "비정상 Buy 색상", group="Volume Colors")
abnormalSellColor  = input.color(color.rgb(251, 64, 64), "비정상 Sell 색상", group="Volume Colors")

// =========================
// 비정상 거래량 설정
// =========================
length     = input.int(20, "비교 캔들 수", minval=1, group="Abnormal Volume")
multiplier = input.float(1.0, "비정상 배수", minval=0, group="Abnormal Volume")

// =========================
// 평균선 설정
// =========================
showAverageLines = input.bool(true, "평균선 표시", group="Average Lines")
avgLineLength    = input.int(20, "평균선 봉 수", minval=1, group="Average Lines")
totalAvgColor    = input.color(color.orange, "전체 주문량 평균선", group="Average Lines")

// =========================
// 비정상 거래량 계산
// =========================
avgVol           = ta.sma(volume, length)
avgTotalVolume   = ta.sma(volume, avgLineLength)
abnormal         = volume > avgVol * (1 + multiplier)

// =========================
// 색상 결정
// =========================
buyColor  = abnormal ? abnormalBuyColor : normalBuyColor
sellColor = abnormal ? abnormalSellColor : normalSellColor

// =========================
// 볼륨 표시
// =========================
plot(volume, style=plot.style_columns, color=sellColor, title="Sell Volume")
plot(buyVolume, style=plot.style_columns, color=buyColor, title="Buy Volume")
plot(showAverageLines ? avgTotalVolume : na, title="Total Volume SMA", color=totalAvgColor, linewidth=1)
