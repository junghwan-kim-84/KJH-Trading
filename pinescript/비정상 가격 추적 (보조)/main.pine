//@version=6
indicator("cRSI + MFI Gap Highlight + Final Trap", shorttitle="cRSI+MFI Final Trap", overlay=false, max_labels_count=500)

// ==========================
// INPUT
// ==========================
src = input.source(close, "Source")

// cRSI
domcycle = input.int(20, minval=10, title="cRSI Dominant Cycle")
vibration = input.int(10, minval=1, title="cRSI Vibration")
leveling = input.float(10.0, minval=1.0, maxval=50.0, title="cRSI Leveling %")

// MFI
mfiLength = input.int(14, minval=1, title="MFI Length")

// ==========================
// LINE OPTIONS
// ==========================
crsiColor = input.color(color.yellow, title="cRSI Color")
mfiColor = input.color(color.blue, title="MFI Color")
crsiWidth = input.int(1, minval=1, maxval=5, title="cRSI Line Width")
mfiWidth = input.int(1, minval=1, maxval=5, title="MFI Line Width")

// ==========================
// GAP BACKGROUND OPTIONS
// ==========================
showGapBg = input.bool(true, title="Show Gap Background")
gapThreshold = input.float(18.0, minval=1.0, title="Gap Background Threshold")
gapCrsiColor = input.color(color.yellow, title="Gap Color (cRSI > MFI)")
gapMfiColor = input.color(color.blue, title="Gap Color (MFI > cRSI)")
gapTransparency = input.int(85, minval=0, maxval=100, title="Gap Background Transparency")

// ==========================
// TRAP OPTIONS
// ==========================
showTrapLabels = input.bool(true, title="Show Trap Labels")

weakGapThreshold = input.float(10.0, minval=0.0, title="Weak Gap Threshold")
strongGapThreshold = input.float(14.0, minval=0.0, title="Strong Gap Threshold")

bullZone = input.float(55.0, minval=0.0, maxval=100.0, title="Bull Trap cRSI Zone")
bearZone = input.float(45.0, minval=0.0, maxval=100.0, title="Bear Trap cRSI Zone")

volumeAvgLength = input.int(3, minval=1, title="Volume Average Length")
volumeMultiplier = input.float(1.0, minval=0.1, step=0.1, title="Volume Multiplier")

useGapFade = input.bool(true, title="Use Gap Fade Condition")
gapFadeLookback = input.int(1, minval=1, maxval=5, title="Gap Fade Lookback")

trapLabelTransparency = input.int(0, minval=0, maxval=100, title="Trap Label Transparency")
bullLabelOffset = input.float(6.0, minval=0.0, maxval=30.0, title="Bull Label Offset")
bearLabelOffset = input.float(6.0, minval=0.0, maxval=30.0, title="Bear Label Offset")

// ==========================
// COLORS
// ==========================
bullTrapColor = color.new(color.red, trapLabelTransparency)
bearTrapColor = color.new(color.green, trapLabelTransparency)

// ==========================
// cRSI CALCULATION
// ==========================
cyclelen = math.max(1, int(domcycle / 2))
cyclicmemory = domcycle * 2
torque = 2.0 / (vibration + 1)
phasingLag = int((vibration - 1) / 2.0)

up = ta.rma(math.max(ta.change(src), 0), cyclelen)
down = ta.rma(-math.min(ta.change(src), 0), cyclelen)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - 100 / (1 + up / down)

var float crsi = na
crsi := torque * (2 * rsi - nz(rsi[phasingLag])) + (1 - torque) * nz(crsi[1])

// ==========================
// DYNAMIC BANDS
// ==========================
float lmax = -999999.0
float lmin = 999999.0
int validCount = 0

for i = 0 to cyclicmemory - 1
    val = crsi[i]
    if not na(val)
        validCount += 1
        if val > lmax
            lmax := val
        if val < lmin
            lmin := val

mstep = validCount > 0 ? (lmax - lmin) / 100.0 : na
aperc = leveling / 100.0

float db = na
if validCount > 0 and not na(mstep)
    if mstep == 0
        db := lmin
    else
        for steps = 0 to 100
            testvalue = lmin + mstep * steps
            below = 0
            for m = 0 to cyclicmemory - 1
                sample = crsi[m]
                below += not na(sample) and sample < testvalue ? 1 : 0
            ratio = below / validCount
            if ratio >= aperc
                db := testvalue
                break

float ub = na
if validCount > 0 and not na(mstep)
    if mstep == 0
        ub := lmax
    else
        for steps = 0 to 100
            testvalue = lmax - mstep * steps
            above = 0
            for m = 0 to cyclicmemory - 1
                sample = crsi[m]
                above += not na(sample) and sample >= testvalue ? 1 : 0
            ratio = above / validCount
            if ratio >= aperc
                ub := testvalue
                break

// ==========================
// MFI
// ==========================
mfi = ta.mfi(hlc3, mfiLength)

// ==========================
// GAP BACKGROUND
// ==========================
gap = math.abs(crsi - mfi)
bullGapBg = crsi > mfi and gap >= gapThreshold
bearGapBg = mfi > crsi and gap >= gapThreshold

bgcolor(showGapBg ? bullGapBg ? color.new(gapCrsiColor, gapTransparency) : bearGapBg ? color.new(gapMfiColor, gapTransparency) : na : na)

// ==========================
// PRICE / VOLUME / GAP STATE
// ==========================
priceUp = close > close[2]
priceDown = close < close[2]

volAvg = ta.sma(volume, volumeAvgLength)
volumeOkay = volume > volAvg * volumeMultiplier

bullGap = crsi - mfi
bearGap = mfi - crsi

bullWeakGap = bullGap > weakGapThreshold
bullStrongGap = bullGap > strongGapThreshold
bearWeakGap = bearGap > weakGapThreshold
bearStrongGap = bearGap > strongGapThreshold

bullZonePass = crsi > bullZone
bearZonePass = crsi < bearZone

bullGapFade = bullGap < bullGap[gapFadeLookback]
bearGapFade = bearGap < bearGap[gapFadeLookback]

// ==========================
// SCORE
// ==========================
bullScore = 0
bullScore += priceUp ? 1 : 0
bullScore += volumeOkay ? 1 : 0
bullScore += bullWeakGap ? 1 : 0
bullScore += bullStrongGap ? 1 : 0
bullScore += bullZonePass ? 1 : 0
bullScore += (useGapFade ? bullGapFade : true) ? 1 : 0

bearScore = 0
bearScore += priceDown ? 1 : 0
bearScore += volumeOkay ? 1 : 0
bearScore += bearWeakGap ? 1 : 0
bearScore += bearStrongGap ? 1 : 0
bearScore += bearZonePass ? 1 : 0
bearScore += (useGapFade ? bearGapFade : true) ? 1 : 0

// ==========================
// STRENGTH
// 3 = strongest
// 2 = medium
// 1 = weakest
// ==========================
bullStrength = bullScore >= 5 ? 3 : bullScore == 4 ? 2 : bullScore == 3 ? 1 : 0
bearStrength = bearScore >= 5 ? 3 : bearScore == 4 ? 2 : bearScore == 3 ? 1 : 0

bullTrapRaw = bullGapBg and bullStrength > 0 and bearStrength == 0
bearTrapRaw = bearGapBg and bearStrength > 0 and bullStrength == 0

// ==========================
// ONE SIGNAL PER BACKGROUND ZONE
// ==========================
newBullZone = bullGapBg and not bullGapBg[1]
newBearZone = bearGapBg and not bearGapBg[1]

var bool bullSignalFiredInZone = false
var bool bearSignalFiredInZone = false

if newBullZone
    bullSignalFiredInZone := false

if newBearZone
    bearSignalFiredInZone := false

finalBullTrap = bullTrapRaw and not bullSignalFiredInZone
finalBearTrap = bearTrapRaw and not bearSignalFiredInZone

if finalBullTrap
    bullSignalFiredInZone := true

if finalBearTrap
    bearSignalFiredInZone := true

// ==========================
// LABEL TEXT
// ==========================
bullLabelText = "Bull(" + str.tostring(bullStrength) + ")"
bearLabelText = "Bear(" + str.tostring(bearStrength) + ")"

// ==========================
// LABEL POSITION
// ==========================
bullLabelPos = math.min(100.0, crsi + bullLabelOffset)
bearLabelPos = math.max(0.0, crsi - bearLabelOffset)

// ==========================
// LABELS
// ==========================
if showTrapLabels and finalBullTrap
    label.new(bar_index, bullLabelPos, bullLabelText, style=label.style_label_down, color=bullTrapColor, textcolor=color.white, size=size.small)

if showTrapLabels and finalBearTrap
    label.new(bar_index, bearLabelPos, bearLabelText, style=label.style_label_up, color=bearTrapColor, textcolor=color.white, size=size.small)

// ==========================
// ALERTS
// ==========================
alertcondition(finalBullTrap, title="Bull Trap", message="Bull Trap detected")
alertcondition(finalBearTrap, title="Bear Trap", message="Bear Trap detected")

alertcondition(finalBullTrap and bullStrength == 3, title="Bull Trap (3)", message="Bull Trap (3) detected")
alertcondition(finalBullTrap and bullStrength == 2, title="Bull Trap (2)", message="Bull Trap (2) detected")
alertcondition(finalBullTrap and bullStrength == 1, title="Bull Trap (1)", message="Bull Trap (1) detected")

alertcondition(finalBearTrap and bearStrength == 3, title="Bear Trap (3)", message="Bear Trap (3) detected")
alertcondition(finalBearTrap and bearStrength == 2, title="Bear Trap (2)", message="Bear Trap (2) detected")
alertcondition(finalBearTrap and bearStrength == 1, title="Bear Trap (1)", message="Bear Trap (1) detected")

// ==========================
// REFERENCE LINES
// ==========================
hline(80, "Overbought", color=color.red)
hline(50, "Middle", color=color.gray)
hline(20, "Oversold", color=color.green)

// ==========================
// PLOTS
// ==========================
lowBandPlot = plot(db, "cRSI Low Band", color=color.gray)
highBandPlot = plot(ub, "cRSI High Band", color=color.gray)
plot(crsi, "cRSI", color=crsiColor, linewidth=crsiWidth)
plot(mfi, "MFI", color=mfiColor, linewidth=mfiWidth)
fill(lowBandPlot, highBandPlot, color=color.new(color.gray, 75))